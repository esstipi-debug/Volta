# ═══════════════════════════════════════════════════════════════
# SUPABASE (Database + Auth + Storage)
# ═══════════════════════════════════════════════════════════════
# Get from: https://supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGc..."
SUPABASE_SERVICE_ROLE_KEY="eyJhbGc..."

# Direct PostgreSQL connection (for Drizzle ORM)
# Format: postgresql://postgres:password@db.supabase.co:5432/postgres
DATABASE_URL="postgresql://postgres:password@db.supabase.co:5432/postgres"

# ═══════════════════════════════════════════════════════════════
# AUTHENTICATION — Supabase Auth (replaces NextAuth)
# ═══════════════════════════════════════════════════════════════
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here-min-32-chars"
NEXTAUTH_URL="http://localhost:3000"

# OAuth Providers (optional in Supabase dashboard)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ═══════════════════════════════════════════════════════════════
# QUEUE & CACHE — Upstash Redis
# ═══════════════════════════════════════════════════════════════
REDIS_URL="redis://default:password@host:port"
UPSTASH_REDIS_REST_URL="https://your-api.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-token"

# ═══════════════════════════════════════════════════════════════
# WEB PUSH NOTIFICATIONS
# ═══════════════════════════════════════════════════════════════
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY="your-public-key"
VAPID_PRIVATE_KEY="your-private-key"
NEXT_PUBLIC_VAPID_PUBLIC_KEY="your-public-key"

# ═══════════════════════════════════════════════════════════════
# APPLICATION
# ═══════════════════════════════════════════════════════════════
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
